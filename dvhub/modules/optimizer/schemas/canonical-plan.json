{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "canonical-plan.json",
  "title": "Canonical Optimization Plan",
  "description": "Normalized 15-minute slot plan produced by any optimizer adapter",
  "type": "object",
  "required": ["optimizer", "slots", "createdAt", "runId"],
  "properties": {
    "optimizer": {
      "type": "string",
      "description": "Optimizer name (e.g., 'eos', 'emhass')"
    },
    "runId": {
      "type": "string",
      "description": "Unique run identifier (UUID)"
    },
    "createdAt": {
      "type": "string",
      "description": "ISO 8601 timestamp of plan creation"
    },
    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["start", "end"],
        "properties": {
          "start": { "type": "string", "description": "ISO 8601 slot start" },
          "end": { "type": "string", "description": "ISO 8601 slot end" },
          "gridImportWh": { "type": "number", "default": 0 },
          "gridExportWh": { "type": "number", "default": 0 },
          "batteryChargeWh": { "type": "number", "default": 0 },
          "batteryDischargeWh": { "type": "number", "default": 0 },
          "targetSocPct": { "type": "number", "default": 0 },
          "expectedProfitEur": { "type": "number", "default": 0 },
          "meta": {
            "oneOf": [
              { "type": "object", "additionalProperties": true },
              { "type": "null" }
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
